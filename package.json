{
    "scripts": {
        "dev": "mix",
        "postinstall": "npm --prefix vite install",
        "watch": "npm run watch:mix & npm run watch:vite & wait",
        "watch:mix": "mix watch",
        "watch:vite": "npm --prefix vite run watch",
        "watch-poll": "mix watch -- --watch-options-poll=1000",
        "hot": "mix watch --hot",
        "hots": "mix watch --hots",
        "production": "npm run production:mix && npm run production:vite && npm run production:rtl",
        "production:mix": "mix --production",
        "production:vite": "npm --prefix vite run build",
        "production:rtl": "find assets/admin \\( -path 'assets/admin/css/*.css' -o -path 'assets/admin/assets/*.css' \\) ! -name '*.rtl.css' -print0 | while IFS= read -r -d '' file; do npx rtlcss \"$file\" > \"${file%.css}.rtl.css\"; done",
        "vite:build": "npm --prefix vite run build",
        "vite:watch": "npm --prefix vite run watch"
    },
    "dependencies": {
        "chroma-js": "^2.4.2",
        "clipboard": "^2.0.11",
        "dompurify": "^3.3.2",
        "echarts": "^5.6.0",
        "element-theme-chalk": "^2.15.9",
        "element-ui": "^2.15.9",
        "fuse.js": "^6.6.2",
        "jquery-datetimepicker": "^2.5.21",
        "lodash": "^4.18.1",
        "moment": "^2.29.4",
        "normalize.css": "^8.0.1",
        "primer-tooltips": "^2.0.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "splitpanes": "^2.4.1",
        "vddl": "^0.7.1",
        "vue": "^2.6.14",
        "vue-echarts": "^6.7.3",
        "vue-html-to-paper": "^1.4.4",
        "vue-router": "^3.5.3",
        "vuex": "^3.6.2"
    },
    "devDependencies": {
        "@babel/preset-react": "^7.22.5",
        "@wordpress/hooks": "^3.4.1",
        "async": "^2.6.4",
        "babel-plugin-component": "^1.1.1",
        "babel-plugin-transform-object-rest-spread": "^6.26.0",
        "babel-polyfill": "^6.26.0",
        "babel-preset-env": "^1.7.0",
        "cross-env": "^7.0.3",
        "laravel-mix": "^6.0.49",
        "less": "^4.1.2",
        "less-loader": "^10.2.0",
        "promise-polyfill": "^8.2.3",
        "resolve-url-loader": "^5.0.0",
        "rtlcss": "^3.5.0",
        "sass": "^1.63.5",
        "sass-loader": "^13.3.2",
        "vue-loader": "^15.9.8",
        "vue-template-compiler": "^2.6.14",
        "webpack-bundle-analyzer": "^4.10.2"
    }
}
