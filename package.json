{
    "type": "module",
    "scripts": {
        "dev": "node resources/vite/vite.js && vite",
        "build": "node resources/vite/vite.js --build && npm run admin && npm run public && npm run gutenberg && npm run elementor && npm run merge-manifests && npm run rtl",
        "admin": "vite build --mode=admin",
        "public": "vite build --mode=public",
        "gutenberg": "vite build --mode=gutenberg",
        "elementor": "vite build --mode=elementor",
        "merge-manifests": "node merge-manifests.js",
        "rtl": "node rtl-generate.js",
        "production": "node resources/vite/vite.js --build --production && npm run admin && npm run public && npm run gutenberg && npm run elementor && npm run merge-manifests && npm run rtl",
        "watch": "npm run dev"
    },
    "dependencies": {
        "chroma-js": "^2.4.2",
        "clipboard": "^2.0.11",
        "dompurify": "^3.0.8",
        "echarts": "^5.6.0",
        "element-theme-chalk": "^2.15.9",
        "element-ui": "^2.15.9",
        "fuse.js": "^6.6.2",
        "jquery-datetimepicker": "^2.5.21",
        "lodash": "^4.17.21",
        "moment": "^2.29.4",
        "normalize.css": "^8.0.1",
        "primer-tooltips": "^2.0.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "splitpanes": "^2.4.1",
        "vddl": "^0.7.1",
        "vue": "^2.7.16",
        "vue-echarts": "^6.7.3",
        "vue-html-to-paper": "^1.4.4",
        "vue-router": "^3.5.3",
        "vuex": "^3.6.2"
    },
    "devDependencies": {
        "@vitejs/plugin-react": "^4.4.1",
        "@vitejs/plugin-vue2": "^2.3.1",
        "@vue/compiler-sfc": "^2.7.16",
        "@wordpress/hooks": "^3.4.1",
        "glob": "^10.3.4",
        "less": "^4.1.2",
        "resolve-url-loader": "^5.0.0",
        "rtlcss": "^3.5.0",
        "sass": "^1.63.5",
        "vite": "^4.4.9",
        "vite-plugin-live-reload": "^3.0.2",
        "vite-plugin-static-copy": "^0.16.0"
    }
}
