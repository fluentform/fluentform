parameters:
    level: 2
    scanDirectories:
        - ../vendor

    # Parse-only: makes the plugin's global helpers + constants known to PHPStan
    # (they are runtime-loaded, not composer-autoloaded) so real undefined-symbol
    # checks keep working without baselining "function not found".
    scanFiles:
        - ../boot/globals.php
        - ../fluentform.php

    bootstrapFiles:
        - ../vendor/autoload.php

    # Unimportant parts of the plugin — templates, CLI tooling, run-once
    # migrations and bundled third-party libraries. Low static-analysis value.
    excludePaths:
        - ../app/Modules/Widgets
        - ../app/Services/Libraries
        - ../app/Views
        - ../app/Modules/CLI
        - ../database/Migrations

    # The curated baseline predates later code; tolerate baseline entries that no
    # longer match (e.g. helpers now resolved via scanFiles, or excluded paths)
    # instead of failing on "ignored error pattern was not matched".
    reportUnmatchedIgnoredErrors: false

    ignoreErrors:
        - '#Unsafe usage of new static\(\)#'

        # Drifted-in findings on code added after the baseline. Benign analyzer
        # limitations (framework magic method, self-call via static::, void
        # render result); ignored here rather than mutating the curated baseline.
        -
            message: '#^Call to an undefined method FluentForm\\Framework\\Http\\Request\\Request::route\(\)\.$#'
            path: ../app/Http/Policies/SubmissionPolicy.php
        -
            message: '#^Unsafe call to private method FluentForm\\App\\Modules\\Acl\\Acl::(hasExplicitFullAccess|filterPermissionCheck)\(\) through static::\.$#'
            path: ../app/Modules/Acl/Acl.php
        -
            message: '#^Result of method FluentForm\\Framework\\View\\View::render\(\) \(void\) is used\.$#'
            path: ../app/Modules/Registerer/Menu.php

        # Modern Stripe inline flow: the raw REST API returns dynamic objects, so
        # property access on them is a benign analyzer limitation on code added
        # after the baseline.
        -
            message: '#^Access to an undefined property object::\$id\.$#'
            path: ../app/Modules/Payments/PaymentMethods/Stripe/StripeInlineProcessor.php

services:
    -
        class: FluentFormDev\PHPStan\ModelPropertyExtension
        tags:
            - phpstan.broker.propertiesClassReflectionExtension

    -
        class: FluentFormDev\PHPStan\AppFacadeExtension
        tags:
            - phpstan.broker.methodsClassReflectionExtension

    -
        class: FluentFormDev\PHPStan\ModelMethodExtension
        tags:
            - phpstan.broker.methodsClassReflectionExtension

    -
        class: FluentFormDev\PHPStan\RequestGuardMethodExtension
        tags:
            - phpstan.broker.methodsClassReflectionExtension

    -
        class: FluentFormDev\PHPStan\DatabaseManagerExtension
        tags:
            - phpstan.broker.methodsClassReflectionExtension

includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon
    - phpstan-baseline.neon
