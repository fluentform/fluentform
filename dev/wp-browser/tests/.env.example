# =============================================================================
#  FluentForm test environment — SANDBOX ONLY
# =============================================================================
#  WPLoader INSTALLS WordPress into TEST_DB_NAME and DROPS/RECREATES its tables
#  on every run. This is DESTRUCTIVE to that database.
#
#    • TEST_DB_NAME must be a DEDICATED, EMPTY, THROWAWAY database.
#    • NEVER point this at your live site's database.
#    • Use a MySQL user scoped to the test DB only (see dev/README.md).
#    • TEST_TABLE_PREFIX must NOT be your site's prefix (must not be "wp_").
#
#  The suite bootstrap (Support/GuardAgainstProductionDb) refuses to run if the
#  DB name has no "test" token, if the prefix is "wp_", or if the environment
#  is flagged production. Copy this file to `.env` and fill in LOCAL values.
# =============================================================================

# Absolute path to a WordPress codebase WPLoader can boot (your local WP root).
WORDPRESS_ROOT_DIR=/path/to/wordpress

# Plugin directory name under wp-content/plugins/ (usually "fluentform").
FLUENTFORM=fluentform

# Plugin file WPLoader actually loads. Point this at YOUR working copy so tests
# and coverage exercise your branch, not the installed release. Either:
#   - an absolute path to this checkout's fluentform.php, or
#   - "fluentform/fluentform.php" to use the installed copy under wp-content/plugins/.
FLUENTFORM_PLUGIN=fluentform/fluentform.php

# --- Sandbox database (throwaway) -------------------------------------------
TEST_DB_HOST=localhost
TEST_DB_NAME=fluentform_tests
TEST_DB_USER=ff_test
TEST_DB_PASSWORD=password
TEST_TABLE_PREFIX=fftest_

# --- Site URL (used by the Acceptance suite) --------------------------------
WORDPRESS_URL=http://localhost:8889
WORDPRESS_DOMAIN=localhost:8889

# --- Acceptance suite (real browser) ----------------------------------------
# WP admin login the browser uses to reach wp-admin.
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=password
# Chromedriver host/port. Start chromedriver with: chromedriver --port=9515
CHROMEDRIVER_HOST=localhost
CHROMEDRIVER_PORT=9515
CHROME_HEADLESS=true
